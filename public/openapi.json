                  "phone_numberA": { "type": "string", "example": "9521634141" },
                  "phone_numberB": { "type": "string", "nullable": true },
                  "college": { "type": "string", "nullable": true, "example": "Govt Engineering College Ajmer" },
                  "city": { "type": "string", "nullable": true, "example": "Jaipur" }
                }
              }
            }
          }
        },
        "responses": {
